# Application
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=300

# CORS
# JSON-array of origins allowed to call this API from a browser.
# Defaults: localhost:3000 (CRA) and localhost:5173 (Vite). Add your dashboard's
# origin here when deploying. NEVER use '*' in production.
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true